# Django Configuration
# Generate a new secret key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Development: DEBUG=True, Production: DEBUG=False
DEBUG=True

# Development: 127.0.0.1,localhost
# Production: your-pythonanywhere-username.pythonanywhere.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
#
# SECURITY NOTES:
# - This key is stored on the server and NEVER exposed to the frontend
# - The frontend sends image data to /api/ocr/scan/ endpoint
# - Backend adds API key and calls Gemini API securely
# - NEVER commit your actual .env file to version control
# - Use different API keys for development and production
# - Add API key restrictions in Google Cloud Console (HTTP referrers/IP addresses)
#
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model Configuration
# Production stable model: gemini-2.0-flash
# Alternative models: gemini-2.0-flash-exp, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# GLM API Configuration
# Get your API key from: https://open.bigmodel.cn/
#
# SECURITY NOTES:
# - This key is stored on the server and NEVER exposed to the frontend
# - Used for content generation, moderation, and review structuring
# - NEVER commit your actual .env file to version control
# - Use different API keys for development and production
#
GLM_API_KEY=your-glm-api-key-here

# GLM Model Configuration
# Multi-model fallback is enabled by default (tries in order):
# 1. glm-4.7-flash (primary - latest flash model)
# 2. glm-4.5-flash (secondary - fallback if primary is busy/unavailable)
#
# To override and use a specific model only, uncomment and set:
# GLM_MODEL=glm-4.7-flash
#
# Alternative models: glm-4, glm-4-plus, glm-4-flash, glm-4-air
# Note: If GLM_MODEL is set, multi-model fallback will be disabled

# GLM API URL Configuration
# Default: Zhipu AI endpoint
# For z.ai integration, verify this is the correct endpoint
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# PostgreSQL Database Configuration (MedVoice Integration)
# Leave these empty for development (will use SQLite)
# Fill these in for MedVoice integration
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_username
POSTGRES_PASSWORD=your_database_password
POSTGRES_HOST=your_database_host
POSTGRES_PORT=5432

# MySQL Database Configuration (Production - PythonAnywhere Free Tier)
# Leave these empty for development (will use SQLite)
# Fill these in for production deployment on PythonAnywhere
DB_NAME=your_database_name
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_HOST=your_database_host.mysql.pythonanywhere-services.com
DB_PORT=3306

# Redis Configuration (Optional - for Celery and caching)
# REDIS_URL=redis://localhost:6379/1
# CELERY_BROKER_URL=redis://localhost:6379/1
